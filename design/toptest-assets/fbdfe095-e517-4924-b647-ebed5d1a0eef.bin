// bridge.js — adapt eyescosmos real data to prototype shape
(function () {
  // photographers.js + supplement.js push to global PHOTOGRAPHERS (var-less)
  // manual-additions.js defines PHOTOGRAPHER_MANUAL_ADDITIONS
  const list = (typeof PHOTOGRAPHERS !== 'undefined' ? PHOTOGRAPHERS : []).slice();
  if (typeof PHOTOGRAPHER_MANUAL_ADDITIONS !== 'undefined') {
    PHOTOGRAPHER_MANUAL_ADDITIONS.forEach(p => list.push(p));
  }
  // Dedup by id, skip placeholders
  const seen = new Set();
  const photographers = [];
  for (const p of list) {
    if (!p || !p.id || p.isPlaceholder) continue;
    if (seen.has(p.id)) continue;
    seen.add(p.id);
    photographers.push(p);
  }

  // Featured / influential ids — bigger stars
  const featured = new Set([
    'daguerre', 'talbot', 'nicephore-niepce', 'nadar', 'muybridge',
    'cameron', 'emerson', 'stieglitz', 'strand', 'weston', 'ansel-adams',
    'steichen', 'atget', 'manray', 'moholy-nagy', 'sander',
    'cartier-bresson', 'capa', 'brassai', 'kertesz',
    'frank', 'evans', 'lange', 'arbus', 'winogrand', 'friedlander',
    'eggleston', 'shore', 'becher', 'gursky', 'struth', 'ruff',
    'sherman', 'prince', 'goldin', 'mapplethorpe',
    'domon', 'tomatsu', 'moriyama', 'araki', 'hiroshi-sugimoto', 'nakahira',
  ]);

  // Era ordering (as in relation-graph.js)
  const eraOrder = ['1839', '1870', '1890', '1910', '1930', '1950', '1970', '1980', '1990', '2000', '2010'];
  const eraIndex = (e) => {
    const i = eraOrder.indexOf(String(e || '').trim());
    return i < 0 ? eraOrder.length : i;
  };
  const yearFrom = (p) => {
    const m = String(p.years || '').match(/(\d{4})/);
    return m ? Number(m[1]) : 1830 + eraIndex(p.era) * 24;
  };

  // === Layout: uniform Poisson-like spread ============================
  // Goal: scatter all photographers across the full canvas without
  // movement-clustering (which created the right-side ring).
  // Strategy: deterministic seed + Poisson-disk sampling.

  const rngFor = (seed) => {
    let s = 0;
    for (let i = 0; i < seed.length; i++) s = (s * 31 + seed.charCodeAt(i)) >>> 0;
    return () => {
      s = (s * 1664525 + 1013904223) >>> 0;
      return s / 4294967295;
    };
  };

  // Sort photographers by influence so featured ones get placed first
  // (and therefore claim better positions in the open canvas).
  const ordered = photographers.slice().sort((a, b) => {
    const fa = featured.has(a.id) ? 1 : 0;
    const fb = featured.has(b.id) ? 1 : 0;
    if (fa !== fb) return fb - fa;
    return yearFrom(a) - yearFrom(b);
  });

  const N = ordered.length;
  // Strategy: jittered grid + per-cell sub-jitter for guaranteed even spread.
  // We pick grid dimensions so cells are roughly square; each cell gets one
  // photographer placed at a random offset inside. This produces a uniform
  // visual distribution without clustering.
  const aspect = 16 / 9; // canvas aspect
  const cols = Math.ceil(Math.sqrt(N * aspect));
  const rows = Math.ceil(N / cols);
  const cellW = 0.92 / cols;
  const cellH = 0.88 / rows;

  // Shuffle deterministically so featured/year-sorted order doesn't band the canvas
  const cellsShuffled = [];
  for (let r = 0; r < rows; r++) {
    for (let c = 0; c < cols; c++) cellsShuffled.push([c, r]);
  }
  // Fisher-Yates with deterministic RNG
  const shuffleRng = rngFor('cells_v2');
  for (let i = cellsShuffled.length - 1; i > 0; i--) {
    const j = Math.floor(shuffleRng() * (i + 1));
    [cellsShuffled[i], cellsShuffled[j]] = [cellsShuffled[j], cellsShuffled[i]];
  }

  const positions = {};
  ordered.forEach((p, idx) => {
    const [c, r] = cellsShuffled[idx % cellsShuffled.length];
    const rand = rngFor(p.id + '_pos');
    // Place inside the cell with margin so neighboring cells stay separated
    const x = 0.04 + c * cellW + (0.15 + rand() * 0.7) * cellW;
    const y = 0.06 + r * cellH + (0.15 + rand() * 0.7) * cellH;
    positions[p.id] = { x, y };
  });

  // ====================================================================

  const movementsMeta = (typeof MOVEMENTS_META !== 'undefined' ? MOVEMENTS_META : {});

  // Assign a hue per movement deterministically
  const hueFor = (move) => {
    let h = 0;
    for (let i = 0; i < move.length; i++) h = (h * 31 + move.charCodeAt(i)) % 360;
    return h;
  };

  // Build movement list actually in use
  const movementSet = new Set();
  photographers.forEach(p => (p.movements || []).forEach(m => m && movementSet.add(m)));
  const movements = Array.from(movementSet);

  // Hash for stable per-id values
  const hash = (s) => {
    let h = 2166136261;
    for (let i = 0; i < s.length; i++) { h ^= s.charCodeAt(i); h = Math.imul(h, 16777619); }
    return (h >>> 0) / 4294967295;
  };

  const MOVEMENTS = {};
  movements.forEach(m => {
    const meta = movementsMeta[m] || { en: m, desc: '' };
    MOVEMENTS[m] = { hue: hueFor(m), label: m, en: meta.en, desc: meta.desc };
  });

  // Country code → カタカナ表記（ISO 3166 alpha-2 を主要なものだけ網羅）
  const COUNTRY_KANA = {
    AR: 'アルゼンチン', AT: 'オーストリア', AU: 'オーストラリア', BE: 'ベルギー',
    BR: 'ブラジル', CA: 'カナダ', CH: 'スイス', CL: 'チリ', CN: 'チュウゴク',
    CU: 'キューバ', CZ: 'チェコ', DE: 'ドイツ', DK: 'デンマーク', EG: 'エジプト',
    ES: 'スペイン', FI: 'フィンランド', FR: 'フランス', GB: 'イギリス', GR: 'ギリシャ',
    HU: 'ハンガリー', ID: 'インドネシア', IE: 'アイルランド', IL: 'イスラエル',
    IN: 'インド', IR: 'イラン', IT: 'イタリア', JP: '日本', KR: '韓国',
    LT: 'リトアニア', LU: 'ルクセンブルク', LV: 'ラトビア', MA: 'モロッコ',
    MX: 'メキシコ', NL: 'オランダ', NO: 'ノルウェー', NZ: 'ニュージーランド',
    PE: 'ペルー', PH: 'フィリピン', PL: 'ポーランド', PT: 'ポルトガル',
    RO: 'ルーマニア', RS: 'セルビア', RU: 'ロシア', SE: 'スウェーデン',
    SK: 'スロバキア', TH: 'タイ', TR: 'トルコ', TW: '台湾', UA: 'ウクライナ',
    US: 'アメリカ', VN: 'ベトナム', YU: 'ユーゴスラビア', ZA: '南アフリカ',
  };
  const toCountryKana = (code) => {
    if (!code) return '';
    // Normalise separators (handles "FR / GB", "US/JP", etc.)
    return code.split(/\s*[\/／・,，]\s*/).map(c => {
      const k = c.trim().toUpperCase();
      return COUNTRY_KANA[k] || c.trim();
    }).join(' / ');
  };

  const out = ordered.map((p) => {
    const pos = positions[p.id];
    const year = yearFrom(p);
    return {
      id: p.id,
      name: p.nameJa || p.name,
      nameEn: p.name || p.nameJa,
      years: p.years || '',
      era: p.era || '',
      country: toCountryKana(p.nationality || ''),
      flag: p.flag || '',
      influence: featured.has(p.id) ? 9 + Math.floor(hash(p.id) * 2) : 4 + Math.floor(hash(p.id) * 4),
      movements: (p.movements || []).slice(),
      url: `https://eyescosmos.github.io/photographers/${p.id}.html`,
      x: pos.x,
      y: pos.y,
      year,
    };
  });

  // Build connections: for each movement, connect all pairs (sparse — chain along era + 1 random cross link)
  const byMove = {};
  out.forEach(p => p.movements.forEach(m => {
    byMove[m] = byMove[m] || []; byMove[m].push(p);
  }));
  const connSet = new Set();
  const connections = [];
  Object.entries(byMove).forEach(([move, list]) => {
    // sort by era then year
    list.sort((a, b) => (eraIndex(a.era) - eraIndex(b.era)) || (a.year - b.year));
    for (let i = 1; i < list.length; i++) {
      const k = [list[i-1].id, list[i].id].sort().join('::');
      if (connSet.has(k)) continue;
      connSet.add(k);
      connections.push([list[i-1].id, list[i].id, move]);
    }
    // add one or two longer-range edges per movement
    if (list.length >= 4) {
      for (let s = 0; s < 2; s++) {
        const a = list[Math.floor(hash(move + s) * list.length)];
        const b = list[Math.floor(hash(move + '_' + s) * list.length)];
        if (a.id === b.id) continue;
        const k = [a.id, b.id].sort().join('::');
        if (connSet.has(k)) continue;
        connSet.add(k);
        connections.push([a.id, b.id, move]);
      }
    }
  });

  window.PHOTOGRAPHERS = out;
  window.MOVEMENTS = MOVEMENTS;
  window.CONNECTIONS = connections;
  window.DATA_READY = true;
  window.__PHOTOGRAPHER_COUNT__ = out.length;
})();
